{
	"name": "ihunt",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently npm:dev:client npm:dev:server",
		"dev:client": "NODE_ENV=development vite dev",
		"dev:server": "NODE_ENV=development nodemon -w server -w vite.config.ts -w node_modules -w .env --exec tsx server/server.ts",
		"build": "yarn build:prisma && yarn build:server",
		"build:client": "vite build",
		"build:prisma": "prisma generate",
		"build:server": "esbuild server/server.ts --bundle --platform=node --target=node24 --format=esm --packages=external --outfile=server.js",
		"build:scripts": "esbuild scripts/*.ts --bundle --platform=node --target=node24 --format=esm --packages=external --outdir=scripts/dist",
		"start": "vite",
		"lint": "oxlint --type-aware",
		"lint:all": "concurrently npm:lint npm:typecheck npm:fmt:check",
		"typecheck": "tsc --noEmit",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"studio": "prisma studio",
		"prepare": "husky",
		"docker:prod": "docker compose -f config/docker-compose.prod.yml --project-directory=."
	},
	"dependencies": {
		"@fastify/cors": "^11.2.0",
		"@imgproxy/imgproxy-js-core": "^1.7.0",
		"@imgproxy/imgproxy-node": "^1.1.0",
		"@prisma/adapter-pg": "^7.4.2",
		"@prisma/client": "^7.4.2",
		"@trpc/server": "^11.16.0",
		"bcryptjs": "^3.0.3",
		"dotenv": "^17.4.0",
		"fastify": "^5.8.4",
		"iron-session": "^8.0.4",
		"sharp": "^0.34.5",
		"superjson": "^2.2.6",
		"thumbhash": "^0.1.1",
		"web-push": "^3.6.7",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@fontsource-variable/geist-mono": "^5.2.7",
		"@fontsource/kanit": "^5.2.8",
		"@hookform/resolvers": "^5.2.2",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-toast": "^1.2.15",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/eslint-plugin-query": "^5.96.1",
		"@tanstack/eslint-plugin-router": "^1.161.6",
		"@tanstack/react-query": "^5.96.1",
		"@tanstack/react-query-devtools": "^5.96.1",
		"@tanstack/react-router": "^1.168.10",
		"@tanstack/react-router-devtools": "^1.166.11",
		"@tanstack/router-plugin": "^1.167.12",
		"@trpc/client": "^11.16.0",
		"@trpc/tanstack-react-query": "^11.16.0",
		"@types/js-cookie": "^3.0.6",
		"@types/node": "^24.12.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/web-push": "^3.6.4",
		"@vitejs/plugin-react": "^6.0.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"concurrently": "^9.2.1",
		"csv-parse": "^6.2.1",
		"embla-carousel-react": "^8.6.0",
		"esbuild": "^0.28.0",
		"eslint": "^9.39.4",
		"eslint-plugin-react-hooks": "^7.0.1",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"input-otp": "^1.4.2",
		"js-cookie": "^3.0.5",
		"lint-staged": "^16.4.0",
		"lucide-react": "^1.7.0",
		"nodemon": "^3.1.14",
		"oxfmt": "^0.43.0",
		"oxlint": "^1.58.0",
		"oxlint-tsgolint": "^0.19.0",
		"pino-pretty": "^13.1.3",
		"prisma": "^7.6.0",
		"react": "^19.2.4",
		"react-admin": "^5.14.5",
		"react-dom": "^19.2.4",
		"react-hook-form": "^7.72.0",
		"react-image-crop": "^11.0.10",
		"rollup-plugin-visualizer": "^7.0.1",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.2",
		"trpc-ui": "npm:trpc-ui-zod4@^1.0.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.0",
		"vite": "^8.0.3",
		"vite-plugin-pwa": "^1.2.0",
		"workbox-core": "^7.4.0",
		"workbox-precaching": "^7.4.0",
		"workbox-recipes": "^7.4.0",
		"workbox-routing": "^7.4.0"
	},
	"resolutions": {
		"react-router": "7.14.0",
		"react-router-dom": "7.14.0"
	},
	"lint-staged": {
		"!(*gen).{js,jsx,ts,tsx}": [
			"yarn run lint",
			"yarn run fmt"
		],
		"*.{json,css,scss,html}": "yarn run fmt"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "yarn@4.13.0"
}
