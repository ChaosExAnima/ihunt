generator client {
    provider = "prisma-client"
    output   = "generated"
}

datasource db {
    provider = "postgres"
}

model Hunt {
    id          Int          @id @default(autoincrement())
    createdAt   DateTime     @default(now())
    scheduledAt DateTime?
    completedAt DateTime?
    name        String
    description String
    place       String?
    warnings    String?
    status      String       @default("pending")
    danger      Int          @default(1)
    maxHunters  Int          @default(5)
    minRating   Int          @default(0)
    photos      Photo[]
    rating      Float?
    comment     String?
    payment     Int
    huntHunters HuntHunter[]

    @@index([status])
    @@index([scheduledAt])
}

model Hunter {
    id          Int          @id @default(autoincrement())
    name        String
    handle      String       @unique
    alive       Boolean      @default(true)
    photos      Photo[]      @relation("Photos")
    avatar      Photo?       @relation("Avatar", fields: [avatarId], references: [id])
    avatarId    Int?         @unique
    money       Int          @default(0)
    user        User?        @relation(fields: [userId], references: [id])
    userId      Int?         @unique
    groupId     Int?
    group       HunterGroup? @relation(fields: [groupId], references: [id])
    bio         String?
    pronouns    String?
    type        String?
    rating      Float        @default(1)
    huntHunters HuntHunter[]

    @@index([alive])
}

model HunterGroup {
    id      Int      @id @default(autoincrement())
    name    String
    hunters Hunter[]
}

model HuntHunter {
    huntId   Int
    hunt     Hunt   @relation(fields: [huntId], references: [id])
    hunterId Int
    hunter   Hunter @relation(fields: [hunterId], references: [id])

    createdAt    DateTime  @default(now())
    expiresAt    DateTime?
    status       String    @default("pending")
    paid         Int?
    fromHunterId Int?

    @@unique([huntId, hunterId])
    @@index([expiresAt])
}

model Photo {
    id       Int     @id @default(autoincrement())
    path     String  @unique
    width    Int
    height   Int
    blurry   String?
    hunter   Hunter? @relation("Photos", fields: [hunterId], references: [id])
    hunterId Int?
    hunt     Hunt?   @relation(fields: [huntId], references: [id])
    huntId   Int?
    avatar   Hunter? @relation("Avatar")

    @@index([huntId, hunterId])
}

model User {
    id         Int         @id @default(autoincrement())
    password   String      @unique
    name       String?
    run        Int         @default(1)
    settings   Json?
    createdAt  DateTime    @default(now())
    updatedAt  DateTime    @updatedAt
    hunter     Hunter?
    userVapids UserVapid[]
}

model UserVapid {
    id             String    @id
    userId         Int
    user           User      @relation(fields: [userId], references: [id])
    payload        String
    expirationTime DateTime?

    @@index([userId, expirationTime])
}
